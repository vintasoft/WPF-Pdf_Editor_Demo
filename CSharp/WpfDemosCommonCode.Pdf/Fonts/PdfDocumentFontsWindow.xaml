<Window x:Class="WpfCommonCode.Pdf.PdfDocumentFontsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vspdfui="clr-namespace:Vintasoft.Imaging.Pdf.Wpf.UI;assembly=Vintasoft.Imaging.Pdf.Wpf.UI"
    xmlns:CustomControls="clr-namespace:WpfCommonCode.CustomControls"
    Title="PDF Document Fonts" Height="430" Width="753" MinHeight="280" MinWidth="580" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28" />
            <RowDefinition Height="37" />
            <RowDefinition Height="*" />
            <RowDefinition Height="26" />
        </Grid.RowDefinitions>

        <vspdfui:WpfPdfFontViewerControl Grid.Row="2" x:Name="pdfFontViewerControl" HorizontalScrollBarVisibility="Disabled"
                                         VerticalScrollBarVisibility="Auto" MouseMove="pdfFontViewerControl_MouseMove"
                                         MouseDoubleClick="pdfFontViewerControl_MouseDoubleClick">
        </vspdfui:WpfPdfFontViewerControl>

        <DockPanel Grid.Row="0">
            <Label HorizontalAlignment="Left" VerticalAlignment="Center">Font</Label>
            <ComboBox Name="fontComboBox" Width="410" Margin="3" HorizontalAlignment="Left" VerticalAlignment="Center" SelectionChanged="fontComboBox_SelectionChanged"/>
            <Label HorizontalAlignment="Left" VerticalAlignment="Center">Cell Size</Label>
            <CustomControls:NumericUpDown x:Name="cellSizeNumericUpDown" Minimum="8" Maximum="512" Value="50" Width="58" Increment="10"  HorizontalAlignment="Left"  VerticalAlignment="Center" ValueChanged="cellSizeNumericUpDown_ValueChanged" />
        </DockPanel>

        <DockPanel Grid.Row="1">
            <Button x:Name="createUnicodeTableButton" Height="26" Width="155" HorizontalAlignment="Left" Margin="5,0,0,0" Click="createUnicodeTable_Click">Create Unicode Table (OCR)</Button>
            <Button x:Name="saveUnicodeTableButton" Height="26" Width="155" HorizontalAlignment="Left" Margin="10,0,0,0" IsEnabled="False" Click="saveUnicodeTable_Click">Save Unicode Table</Button>
        </DockPanel>

        <Label x:Name="statusLabel" Grid.Row="3" HorizontalAlignment="Left" VerticalAlignment="Center" />
    </Grid>
</Window>

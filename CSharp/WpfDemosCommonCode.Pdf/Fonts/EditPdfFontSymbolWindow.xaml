<Window x:Class="WpfCommonCode.Pdf.EditPdfFontSymbolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit PDF Font Symbol" Height="520" Width="368"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner">
    <Grid>
        <DockPanel Height="30" VerticalAlignment="Top">
            <Label x:Name="unicodeSymbolLabel" Content="Unicode symbol:" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <TextBox x:Name="unicodeSymbolTextBox" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Margin="5,5,0,0" Height="18"/>
        </DockPanel>
        <DockPanel>
            <Canvas x:Name="glyphCanvas" Width="352" Height="347"></Canvas>
        </DockPanel>
        <DockPanel Height="40" VerticalAlignment="Bottom">
            <Button x:Name="okButton" Content="OK" HorizontalAlignment="Left" VerticalAlignment="Center" Height="26" Width="95" Click="okButton_Click" Margin="80,0,0,0"/>
            <Button x:Name="cancelButton" Content="Cancel" HorizontalAlignment="Left" VerticalAlignment="Center" Height="26" Width="95" Margin="10,0,0,0" Click="cancelButton_Click"/>
        </DockPanel>
    </Grid>
</Window>
